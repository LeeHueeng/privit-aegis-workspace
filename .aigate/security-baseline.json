  "scope": {
    "maxPassiveDepth": 3,
    "maxPassivePages": 100,
    "requireLoopbackForLocal": true,
    "disallowProductionActiveScan": true,
    "requiredFalseSafetyFlags": [
      "destructive_tests",
      "brute_force",
      "data_exfiltration",
      "persistence",
      "production_active_scan"
    ]
  },
  "webConsole": {
    "requiredDefaultHost": "127.0.0.1",
    "requiredHeaders": [
      "content-security-policy",
      "x-content-type-options",
      "referrer-policy",
      "x-frame-options",
      "permissions-policy",
      "cross-origin-opener-policy",
      "cache-control"
    ],
    "hstsWhenTlsOnly": true
  },
