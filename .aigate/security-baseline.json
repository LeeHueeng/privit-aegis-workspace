{
  "version": 1,
  "profile": "owasp-github-local-passive",
  "sources": [
    {
      "name": "OWASP HTTP Security Response Headers Cheat Sheet",
      "url": "https://cheatsheetseries.owasp.org/cheatsheets/HTTP_Headers_Cheat_Sheet.html"
    },
    {
      "name": "OWASP Authentication Cheat Sheet",
      "url": "https://cheatsheetseries.owasp.org/cheatsheets/Authentication_Cheat_Sheet.html"
    },
    {
      "name": "OWASP Cross-Site Request Forgery Prevention Cheat Sheet",
      "url": "https://cheatsheetseries.owasp.org/cheatsheets/Cross-Site_Request_Forgery_Prevention_Cheat_Sheet.html"
    },
    {
      "name": "OWASP Web Security Testing Guide",
      "url": "https://owasp.org/www-project-web-security-testing-guide/"
    },
    {
      "name": "OWASP WSTG Testing Cross Origin Resource Sharing",
      "url": "https://owasp.org/www-project-web-security-testing-guide/latest/4-Web_Application_Security_Testing/11-Client-side_Testing/07-Testing_Cross_Origin_Resource_Sharing"
    },
    {
      "name": "OWASP WSTG Test for Content Security Policy",
      "url": "https://owasp.org/www-project-web-security-testing-guide/latest/4-Web_Application_Security_Testing/02-Configuration_and_Deployment_Management_Testing/12-Test_for_Content_Security_Policy"
    },
    {
      "name": "OWASP WSTG Review Web Page Content for Information Leakage",
      "url": "https://owasp.org/www-project-web-security-testing-guide/latest/4-Web_Application_Security_Testing/01-Information_Gathering/05-Review_Web_Page_Content_for_Information_Leakage"
    },
    {
      "name": "OWASP API Security Top 10 2023",
      "url": "https://owasp.org/API-Security/editions/2023/en/0x11-t10/"
    },
    {
      "name": "GitHub Actions Secure Use Reference",
      "url": "https://docs.github.com/en/actions/reference/security/secure-use"
    },
    {
      "name": "MDN Content Security Policy",
      "url": "https://developer.mozilla.org/en-US/docs/Web/HTTP/Guides/CSP"
    }
  ],
  "scope": {
    "maxPassiveDepth": 3,
    "maxPassivePages": 100,
    "requireLoopbackForLocal": true,
    "disallowProductionActiveScan": true,
    "requiredFalseSafetyFlags": [
      "destructive_tests",
      "brute_force",
      "data_exfiltration",
      "persistence",
      "production_active_scan"
    ]
  },
  "webConsole": {
    "requiredDefaultHost": "127.0.0.1",
    "requiredHeaders": [
      "content-security-policy",
      "x-content-type-options",
      "referrer-policy",
      "x-frame-options",
      "permissions-policy",
      "cross-origin-opener-policy",
      "cache-control"
    ],
    "hstsWhenTlsOnly": true
  },
  "frontendAdvisory": {
    "maxHeaderAuditPages": 20,
    "maxContentReviewAssets": 12,
    "authFormsMustUsePost": true,
    "csrfRequiredForStateChangingForms": true,
    "passwordAutocompleteRecommended": true,
    "sensitiveResponsesNoStore": true,
    "hidePoweredByHeader": true,
    "sessionCookiesRequireFlags": [
      "HttpOnly",
      "SameSite",
      "Secure when applicable"
    ],
    "recommendedHeaders": [
      "content-security-policy",
      "strict-transport-security",
      "x-content-type-options",
      "referrer-policy",
      "permissions-policy",
      "cache-control"
    ],
    "passiveProbes": {
      "maxProbeRequests": 80,
      "maxMethodTargets": 12,
      "sensitiveFiles": [
        "/.env",
        "/.git/config",
        "/.svn/entries",
        "/config.json",
        "/backup.zip",
        "/db.sql",
        "/phpinfo.php"
      ],
      "apiDocs": [
        "/openapi.json",
        "/swagger.json",
        "/swagger-ui",
        "/swagger-ui/index.html",
        "/api-docs",
        "/redoc"
      ],
      "adminPaths": [
        "/admin",
        "/admin/login",
        "/dashboard",
        "/manage",
        "/console"
      ],
      "debugPaths": [
        "/debug",
        "/actuator",
        "/actuator/env",
        "/metrics",
        "/health",
        "/server-status",
        "/_next/webpack-hmr"
      ],
      "sourceMaps": [
        "/main.js.map",
        "/app.js.map",
        "/static/js/main.js.map",
        "/_next/static/chunks/main.js.map"
      ]
    }
  },
  "githubActions": {
    "forbidPullRequestTarget": true,
    "requireReadOnlyContentsPermission": true,
    "requireJobTimeout": true,
    "requireCheckoutPersistCredentialsFalse": true,
    "warnOnTagPinnedActions": true
  }
}
