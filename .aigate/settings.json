        "healthUrl": "http://127.0.0.1:11434/api/tags",
        "apiStyle": "openai-chat",
        "apiKeyEnv": "",
        "docsUrl": "https://github.com/ollama/ollama/blob/main/docs/api.md",
        "presets": [
          "llama3.1:8b",
          "qwen3.5:8b",
          "gemma4:9b",
          "gpt-oss:20b"
        ]
      },
      "api": {
        "label": "Direct API",
        "providerType": "api",
        "enabled": false,
        "command": "curl",
        "rootFile": "",
        "sidecarFile": "",
        "model": "gpt-5.5",
        "modelFlag": "--model",
        "effort": "",
        "approvalMode": "",
        "permissionMode": "",
        "sandbox": "",
        "outputFormat": "json",
        "fallbackModel": "",
