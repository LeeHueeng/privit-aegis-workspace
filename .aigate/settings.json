          "gpt-5.4",
          "gpt-5.4-mini",
          "gpt-5.3-codex-spark"
        ]
      }
    },
    "updatedAt": "2026-07-08T10:23:19.892Z"
  },
  "aiRootFiles": "protect",
  "serverEnforcement": {
    "gitlab": {
      "onlyAllowMergeIfPipelineSucceeds": "auto"
    },
    "github": {
      "requiredChecksEnforced": "auto"
    }
  }
}
